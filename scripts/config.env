# ============================================
# CONFIGURACIÓN CENTRALIZADA DE LA PLATAFORMA
# ============================================

# Directorios base
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
PROYECTO_ROOT="$(dirname "$SCRIPTS_DIR")"
CATALOGO_DIR="$PROYECTO_ROOT/catalogo"
BASE_DIR="/srv"
DB_DIR="$SCRIPTS_DIR/databases"
CREDENTIALS_DIR="$DB_DIR/credentials"
LOGS_DIR="$SCRIPTS_DIR/logs"

# Rango de puertos por entorno
PUERTO_MIN_DEV=8000
PUERTO_MAX_DEV=8999
PUERTO_MIN_PROD=9000
PUERTO_MAX_PROD=9999

# Archivos de base de datos
EMPRESAS_DB="$DB_DIR/empresas.json"
SERVICIOS_DB="$DB_DIR/servicios.json"
PUERTOS_DB="$DB_DIR/puertos.json"

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARN, ERROR
DEBUG="${DEBUG:-0}"

# Docker
DOCKER_NETWORK_SUFFIX="_net"
COMPOSE_TIMEOUT=30

# Seguridad
CREDENTIAL_PERMS=600
DB_PERMS=640

# Backups
BACKUP_ENABLED=1
BACKUP_RETENTION_DAYS=7
BACKUP_DIR="/srv/backups"

# Defaults
DEFAULT_DB_USER="user"
ADMIN_USER="admin"

# Confirmación automática en destructivos
FORCE_MODE="${FORCE_MODE:-0}"  # Set to 1 to skip confirmations
