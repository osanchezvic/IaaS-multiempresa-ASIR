# =========================================
# CONFIGURACIÓN BACKUPS
# =========================================

# Ruta base de backups
BACKUP_BASE_DIR="/srv/backups"

# Días de retención (antiguos se eliminan)
RETENTION_DAYS=30

# Registro de backups (auditoría)
BACKUP_LOG="$BACKUP_BASE_DIR/backups.log"

# Compresión (gzip por defecto)
COMPRESS="gzip"
